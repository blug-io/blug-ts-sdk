{
  "name": "@blug-io/sdk",
  "version": "0.1.4",
  "description": "TypeScript SDK for Blug API key-protected endpoints",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint src",
    "test": "bun test",
    "biome:ci": "biome ci src",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package-json.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.8.2",
    "@types/bun": "^1.2.12"
  },
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": ["dist"]
}
